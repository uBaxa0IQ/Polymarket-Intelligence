# PostgreSQL
POSTGRES_PASSWORD=poly

# Dashboard auth (JWT + single-user login)
AUTH_SECRET_KEY=change-me-to-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# CORS (comma-separated origins for the FastAPI app)
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# LLM — Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# LLM — Yandex Cloud
YANDEX_LLM_API_KEY=
YANDEX_LLM_FOLDER_ID=
YANDEX_SEARCH_API_KEY=
YANDEX_SEARCH_FOLDER_ID=
# Yandex web search when stage2 enable_web_search: gensearch | responses
# YANDEX_WEB_SEARCH_MODE=gensearch
# YANDEX_RESPONSES_ENDPOINT=https://llm.api.cloud.yandex.net/v1/responses
# YANDEX_RESPONSES_FORCE_WEB_SEARCH=true

# Polymarket CLOB (for live betting)
POLYMARKET_PRIVATE_KEY=0x...
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
# For proxy/email/social Polymarket wallets:
# POLYMARKET_PROXY_ADDRESS=0x...
# Optional override (defaults: 1 with proxy address, otherwise 0)
# POLYMARKET_SIGNATURE_TYPE=1
