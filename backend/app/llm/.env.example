# --- Anthropic (AnthropicLLMAdapter) ---
ANTHROPIC_API_KEY=

# --- Yandex OpenAI-compatible (YandexLLMAdapter) ---
YANDEX_LLM_API_KEY=

# Если в коде передаёте короткое имя модели (например yandexgpt/rc), укажите каталог:
# YANDEX_LLM_FOLDER_ID=

# По умолчанию: https://llm.api.cloud.yandex.net/v1/chat/completions
# YANDEX_LLM_ENDPOINT=

# bearer → Authorization: Bearer <key>
# api_key → Authorization: Api-Key <key>
YANDEX_LLM_AUTH_MODE=bearer

YANDEX_LLM_TIMEOUT_SECONDS=120

# true / false — заголовок x-data-logging-enabled
YANDEX_LLM_DATA_LOGGING_ENABLED=false

# Режим веб-поиска для Yandex при enable_web_search: gensearch (GenSearch) | responses (Responses API + web_search)
# YANDEX_WEB_SEARCH_MODE=gensearch
# YANDEX_RESPONSES_ENDPOINT=https://llm.api.cloud.yandex.net/v1/responses
# Принудительный вызов web_search (tool_choice); false — модель решает сама
# YANDEX_RESPONSES_FORCE_WEB_SEARCH=true

# Подсказка для factory.create_llm_adapter(provider, ...): anthropic | yandex
# LLM_PROVIDER=yandex

# Модель задаётся в коде при вызове complete_text; для Yandex часто полный URI:
# LLM_MODEL=gpt://b1g7n4milub45em0t8sp/qwen3-235b-a22b-fp8/latest
